        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"mode\": \"delta\"}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "sync-02-request",
      "name": "Delta Sync",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        40,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\n\nconst created = result.created || 0;\nconst updated = result.updated || 0;\nconst unchanged = result.unchanged || 0;\nconst withLogos = result.withLogos || 0;\nconst duration = result.duration || 'unknown';\nconst errors = result.errors || 0;\n\nconst total = created + updated + unchanged;\n\nconsole.log(`🔄 Company Sync Complete`);\nconsole.log(`   Total: ${total} | New: ${created} | Updated: ${updated} | Unchanged: ${unchanged}`);\nconsole.log(`   Logos: ${withLogos} | Duration: ${duration} | Errors: ${errors}`);\n\nif (errors > 0) {\n  console.log(`⚠️ WARNING: ${errors} errors during sync`);\n}\n\nreturn {\n  json: {\n    summary: `Sync: ${created} new, ${updated} updated, ${unchanged} unchanged (${duration})`,\n    ...result\n  }\n};"
      },
      "id": "sync-03-log",
      "name": "Log Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        280,
        300
      ]
    }
  ],
