# ==========================================
# Empliq - Docker Environment Variables
# ==========================================
# Copia este archivo a .env y ajusta los valores

# PostgreSQL Local
POSTGRES_USER=empliq
POSTGRES_PASSWORD=empliq_dev_password
POSTGRES_DB=empliq
DATABASE_URL=postgresql://empliq:empliq_dev_password@postgres:5432/empliq

# Node Environment
NODE_ENV=development

# Supabase Auth (production — supabase.musuq.me)
# Get these values from /opt/empliq/credentials.env on the Oracle server
JWT_SECRET=your-production-jwt-secret
SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
