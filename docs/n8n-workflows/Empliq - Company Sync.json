      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.empliq.io/api/companies/sync",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "5ae18999d0077fbe53971f6258acf88b079adeeea15e6f127199495196767543"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
